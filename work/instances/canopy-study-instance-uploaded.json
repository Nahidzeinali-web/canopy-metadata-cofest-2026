},"Study Domain":[{"@value":"Health Behaviors"}],"Other Domain, Specify":[{"@value":"Time-restricted eating (behavioral/nutritional intervention) for glycemic control in prediabetes — not a COVID-era domain covered by the controlled list above"}],"Data Collection Methods":[{"@value":"Survey"}],"Other Data Collection Methods":[{"@value":"Venous blood draw for fasting plasma glucose and HbA1c per SOP SPbE-2026-SOP-001; anthropometry (weight, BMI) and blood pressure measurement at screening/baseline and week 12"}],"Study Population Focus":[{"@value":"Adults"}],"Clinical Trials gov URL":{},"Study Website URL":{},"Primary Publication URL":[{"@id":"https://pubmed.ncbi.nlm.nih.gov/31813466/"}],"Study Design":[{"@value":"Interventional or Clinical Trial"}],"Other Study Design":[{"@value":"Two-arm, parallel-group, randomized controlled pilot trial"}],"Species":[{"@value":"Human"}],"Sample Collection":[{"@value":"Prospective Sample"}],"Data Types":[{"@value":"Clinical"},{"@value":"Behavioral"},{"@value":"Biologic Specimens"},{"@value":"Questionnaire or Survey"},{"@value":"Supporting Documents"}],"Other Data Types":[],"Genomic Data Types":[{"@value":"Other"}],"Other Genomic Data Types":[{"@value":"Not applicable — no genomic data collected in this study"}],"Phenotypes":[{"@value":"Other"}],"Other Phenotypes":[{"@value":"Not applicable — phenotype-style data limited to standard clinical/anthropometric measures already captured under Data Types"}],"Sample Types":[{"@value":"Other"}],"Other Sample Types":[{"@value":"Plasma (fasting glucose) and whole blood (HbA1c) aliquots, collected and handled per SOP SPbE-2026-SOP-001"}],"Genotypes":[{"@value":"Other"}],"Other Genotypes":[{"@value":"Not applicable — no genotyping performed"}],"Sequencing Data Types":[{"@value":"Other"}],"Other Sequencing Data Types":[{"@value":"Not applicable — no sequencing performed"}],"Genomic Analyses Types":[{"@value":"Other"}],"Other Genomic Analyses Types":[{"@value":"Not applicable — no genomic analyses performed"}],"Genomic Array Data Types":[{"@value":"Other"}],"Other Genomic Array Data Types":[{"@value":"Not applicable — no array-based genomic data collected"}],"Acknowledgment Statement":{"@value":"This is a fully synthetic dataset and protocol generated for the ISMB/ECCB CollaborationFest 2026 Canopy metadata-generation project. No human subjects were enrolled and no real data are reported."},"Study Description":{"@value":"A two-arm, parallel-group, randomized pilot trial (protocol SPbE-2026, v1.0) evaluating the effect of a 10-hour time-restricted eating (TRE) window, relative to a habitual eating schedule, on glycemic control in adults aged 40–65 with prediabetes. Forty participants were enrolled across four sites (United States, Germany, Spain, Canada) and randomized 1:1, stratified by site and sex, and followed for 12 weeks. The primary endpoint is change in fasting plasma glucose from baseline to week 12; secondary endpoints include change in HbA1c, body weight/BMI, and systolic blood pressure, plus adherence and safety. As a pilot, the study is not powered for confirmatory inference. This is a fully synthetic dataset with fabricated subjects and results, created for the ISMB/ECCB CollaborationFest 2026 AI-assisted metadata generation project."},"General Research Use":[{"@value":"Publication required"}],"Health/Medical/Biomedical":[{"@value":"Health or Biomedical Purpose"}],"Conditions/Diseases":[{"@value":"Publication required"}],"Related Conditions":{"@value":"Prediabetes (MONDO:0005827)"},"Other Data Use Limitations":{"@value":"None beyond publication attribution — this is a synthetic dataset released under an open license for tooling/education (CoFest 2026); no real human-subjects data or regulatory restrictions apply."},"@context":{"rdfs":"http://www.w3.org/2000/01/rdf-schema#","xsd":"http://www.w3.org/2001/XMLSchema#","pav":"http://purl.org/pav/","schema":"http://schema.org/","oslc":"http://open-services.net/ns/core#","skos":"http://www.w3.org/2004